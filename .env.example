# ==============================================================================
# mcp-octo-db - Ejemplo de Configuración de Entorno
# Copia este archivo a ".env" y edita con tus credenciales reales.
# ==============================================================================

# ------------------------------------------------------------------------------
# BASE DE DATOS PRINCIPAL (Por defecto se mapea a "default")
# ------------------------------------------------------------------------------
DB_TYPE=postgres            # Opciones: postgres, mysql, mariadb
DB_HOST=localhost
DB_PORT=5432
DB_USER=mi_usuario
DB_PASSWORD=mi_contraseña
DB_NAME=mi_base_de_datos
DB_SSLMODE=disable          # Solo necesario para postgres (disable, require, etc.)

# ------------------------------------------------------------------------------
# EJEMPLO DE BASE DE DATOS ADICIONAL (Mapeada a "analytics")
# Puedes agregar tantas como necesites usando diferentes sufijos (ej: _PROD, _DEV)
# ------------------------------------------------------------------------------
# DB_TYPE_ANALYTICS=mysql
# DB_HOST_ANALYTICS=127.0.0.1
# DB_PORT_ANALYTICS=3306
# DB_USER_ANALYTICS=analytics_user
# DB_PASSWORD_ANALYTICS=analytics_password
# DB_NAME_ANALYTICS=analytics_db

# ------------------------------------------------------------------------------
# EJEMPLO DE BASE DE DATOS SQLITE (Mapeada a "sqlite_test")
# ------------------------------------------------------------------------------
# DB_TYPE_SQLITE_TEST=sqlite
# DB_NAME_SQLITE_TEST=/ruta/absoluta/a/mi_base_de_datos.db
